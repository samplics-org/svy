# Package-specific rules only — common patterns (Python, Rust, caches,
# editors, OS litter) live in the repository-root .gitignore and apply here.

# Private working docs (local-only, not published)
docs/
scripts/
metadata/
build.md
CONTRIBUTING.md

# Build logs
*.build

# Rust toolchain state (workspace pins the toolchain globally)
rust-toolchain
rust-toolchain.toml
